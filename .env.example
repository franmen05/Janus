# =============================================================================
# Janus Production Environment Variables
# =============================================================================
#
# Nginx Proxy Manager setup (required before first deploy):
# 1. Create external Docker network: docker network create npm-proxy
# 2. Connect NPM to it: add "npm-proxy" network to NPM's docker-compose.yml
# 3. In NPM web UI, create Proxy Host for your domain:
#    - Forward to: janus-frontend  Port: 80  (serves the Angular app)
#    - Enable SSL (Let's Encrypt)
#    - Under "Advanced", add custom location:
#        Location: /api
#        Forward to: janus-backend  Port: 8080
# 4. Add GitHub Secrets: VPS_HOST, VPS_USER, VPS_SSH_KEY, VPS_DEPLOY_PATH
# =============================================================================

# PostgreSQL
DB_USERNAME=janus
DB_PASSWORD=change_me_strong_password

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# Application URLs
CORS_ORIGINS=https://janus.yourdomain.com
FRONTEND_URL=https://janus.yourdomain.com

# External integrations (leave empty if not used)
EXTERNAL_API_KEY=
# Set to the actual BillFlow service URL if used (e.g. http://billflow-host:8081)
BILLFLOW_URL=
BILLFLOW_API_KEY=
